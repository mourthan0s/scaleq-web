# ─────────────────────────────────────────────────────────────
# SCALEQ website — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for canonical URLs, sitemap, hreflang)
NEXT_PUBLIC_SITE_URL=https://scale-q.com

# Contact form email delivery, via Resend (https://resend.com).
# Sign up, verify the scale-q.com sending domain (a few DNS records), then
# create an API key and paste it below. Without this, submissions are
# still accepted and logged server-side, but no email is sent.
RESEND_API_KEY=

# Where the notification email for each new submission is sent.
# Defaults to info@scale-q.com if left empty.
CONTACT_TO_EMAIL=

# The "from" address used for both the internal notification and the
# submitter's auto-reply. Must be on the domain verified in Resend.
CONTACT_FROM_EMAIL=SCALEQ Website <no-reply@scale-q.com>

# Optional secondary forward — CRM / automation webhook (Zapier/Make/n8n).
# The /api/contact route also forwards validated submissions here as JSON,
# in addition to email delivery. Leave empty to skip.
CONTACT_WEBHOOK_URL=

# Analytics — loaded ONLY after explicit cookie consent.
# Leave empty to disable entirely.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
